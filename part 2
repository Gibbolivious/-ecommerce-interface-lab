:root {
  --primary-color: #1e2a38;
  --accent-color: #ff7a00;
  --light-bg: #f5f7fa;
  --card-bg: #ffffff;
  --text-color: #333;
  --border-color: #ddd;
  --success: #27ae60;
  --error: #c0392b;
}

*{
  max-width: 100%;
  height: auto;
}

/* Body */
body {
  font-family: Arial, Helvetica, sans-serif;
  background-color: var(--light-bg);
  color: var(--text-color);
  margin: 0;
  line-height: 1.6;
 
}

/* Headings */
h1,
h2,
h3 {
  font-family: Georgia, serif;
  color: var(--primary-color);

  flex-direction: column;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

nav{
  flex-direction: column;
  flex-direction: row;
 
}

/* Images */
img {
  max-width: 100%;
  display: block;
}

/* Navigation */
nav ul {
  list-style: none;
  padding: 0;
}

nav li {
  display: inline-block;
  margin-right: 15px;
}

nav a {
  text-decoration: none;
  color: var(--primary-color);
  transition: 0.3s ease;
}

/* Hover */
nav a:hover,
a:hover {
  color: var(--accent-color);
  text-decoration: underline;
}

button {
  background-color: var(--accent-color);
  color: white;
  border: none;
  padding: 8px 14px;
  cursor: pointer;
  transition: 0.3s ease;
}

/* Button hover */
button:hover {
  background-color: var(--primary-color);
}

/* Button active (pressed) */
button:active {
  transform: scale(0.97);
}

/* Focus accessibility */
input:focus,
button:focus {
  outline: 3px solid var(--accent-color);
}

section[aria-labelledby="product-grid-heading"] {
  grid-template-columns: 2fr 1fr;
  display: grid;
  width: 90vw;
  vertical-align: top;
  margin: 10px;
  padding: 15px;
  background-color: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  transition: 0.3s ease;

  animation: bounce-and-fade 2s infinite ease-in-out;
}

#product-form{
  grid-template-columns: 2fr 1fr;
  display: grid;
}

section[aria-labelledby="hero-heading"]{
  text-align: center;
}

/* Hover card */
section[aria-labelledby="product-grid-heading"] article:hover {
  transform: scale(1.03);
}

/* Alternate background */
section[aria-labelledby="product-grid-heading"] article:nth-child(even) {
  background-color: #f0f0f0;
}

/* Empty Cart */
.cart-container:empty {
  padding: 20px;
  border: 2px dashed var(--border-color);
  background-color: #fff8e6;
}

/* Currency Symbol */
.price::before {
  content: "$";
  color: var(--accent-color);
  font-weight: bold;
}

/* Required fields */
input:required {
  border: 2px solid var(--error);
}

/* Valid fields */
input:valid {
  border: 2px solid var(--success);
}

/* Table Styling */
table {
  width: 100%;
  border-collapse: collapse;
  background-color: var(--card-bg);
}

th,
td {
  border: 1px solid var(--border-color);
  padding: 10px;
}

/* First column bold */
td:first-child,
th:first-child {
  font-weight: bold;
  color: var(--primary-color);
}

/* Account page order list styling */
dl dt {
  font-weight: bold;
  color: var(--primary-color);
}

/* Add decorative quotes to reviews */
blockquote::before {
  content: "“";
  font-size: 25px;
  color: var(--accent-color);
}

blockquote::after {
  content: "”";
  font-size: 25px;
  color: var(--accent-color);
}

